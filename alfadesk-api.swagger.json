    "/ticket": {
      "get": {
        "tags": [
          "ticket"
        ],
        "summary": "Získa zoznam ticketov s filtrami.",
        "description": "Vráti zoznam ticketov podľa zadaných filtrov. Bežný užívateľ vidí len svoje vytvorené tickety, administrátor vidí všetky.",
        "operationId": "zoznamTicketov",
        "security": [
          {
            "SessionAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vyriesene": {
                    "type": "boolean",
                    "description": "Filter podľa stavu riešenia",
                    "example": false
                  },
                  "datum_od": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Filter od dátumu vytvorenia",
                    "example": "2025-01-01T00:00:00Z"
                  },
                  "datum_do": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Filter do dátumu vytvorenia",
                    "example": "2025-12-31T23:59:59Z"
                  },
                  "vytvoril": {
                    "type": "integer",
                    "format": "uint64",
                    "description": "Filter podľa ID užívateľa, ktorý vytvoril ticket (len pre admin)",
                    "example": 12
                  },
                  "vyriesil": {
                    "type": "integer",
                    "format": "uint64",
                    "description": "Filter podľa ID užívateľa, ktorý vyriešil ticket (len pre admin)",
                    "example": 44
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Počet výsledkov na stránku",
                    "example": 50,
                    "default": 50
                  },
                  "stranka": {
                    "type": "integer",
                    "description": "Číslo stránky",
                    "example": 1,
                    "default": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Zoznam ticketov",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tickety": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TicketR"
                      }
                    },
                    "stranka": {
                      "type": "integer",
                      "example": 1
                    },
                    "limit": {
                      "type": "integer",
                      "example": 50
                    },
                    "pocet": {
                      "type": "integer",
                      "description": "Celkový počet výsledkov",
                      "example": 156
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Nie ste prihlásený"
          },
          "500": {
            "$ref": "#/components/responses/GenerickaChyba"
          }
        }
      },
      "post": {
