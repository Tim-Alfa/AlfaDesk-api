  "paths": {
    "/uzivatel/login": {
      "post": {
        "tags": [
          "uzivatel"
        ],
        "summary": "Prihlásenie užívateľa.",
        "description": "Prihlási užívateľa do systému a vytvorí reláciu. Odošlite email a heslo v tele požiadavky. Po úspešnom prihlásení server vráti PHP session cookie (PHPSESSID), ktorý sa automaticky uloží a bude sa posielať so všetkými ďalšími požiadavkami.\n\n**Postup:**\n1. Zadajte váš email a heslo\n2. Kliknite \"Try it out\"\n3. Po úspešnom prihlásení bude session automaticky aktívna pre všetky ďalšie požiadavky\n4. Ak chcete sa odhlásiť, zavolajte POST /uzivatel/logout",
        "operationId": "prihlasitUzivateleaPost",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "login": {
                    "type": "string",
                    "format": "email",
                    "example": "janko.hrasko@example.com"
                  },
                  "heslo": {
                    "type": "string",
                    "example": "TajneHeslo123"
                  }
                },
                "required": ["login", "heslo"]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Užívateľ úspešne prihlásený. Vrátená response obsahuje údaje užívateľa a v cookies je uložená PHP session.",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "PHPSESSID=abcd1234efgh5678; Path=/; HttpOnly; Secure"
                },
                "description": "PHP session cookie - automaticky sa posiela v ďalších požiadavkách"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Uzivatel"
                }
              }
            }
          },
          "401": {
            "description": "Neplatné prihlasovacie údaje alebo užívateľ už prihlásený"
          },
          "500": {
            "$ref": "#/components/responses/GenerickaChyba"
          }
        }
      }
    },
